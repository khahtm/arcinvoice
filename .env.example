# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Wallet / Chain
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=<walletconnect-project-id>

# Contracts (Arc network)
NEXT_PUBLIC_FACTORY_ADDRESS_V1=0x
NEXT_PUBLIC_FACTORY_ADDRESS_V3=0x
NEXT_PUBLIC_USDC_ADDRESS=0x

# Email (Resend)
RESEND_API_KEY=re_<key>
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Kleros arbitration
# Secret used to verify the HMAC-SHA256 signature on incoming Kleros webhooks
KLEROS_WEBHOOK_SECRET=<random-secret>

# Deployment (Hardhat)
DEPLOYER_PRIVATE_KEY=0x<private-key>
ARC_TESTNET_RPC_URL=https://rpc.arc-testnet.example.com
ARC_MAINNET_RPC_URL=https://rpc.arc-mainnet.example.com
